# Resend (https://resend.com) — create an API key and verify your sending domain for production.
RESEND_API_KEY=re_eXz74RWS_65F8NC9XRibrbEhTUpW5R2cG

# Optional: defaults to Resend’s sandbox sender for testing (see Resend docs).
# Example: Payvol <newsletter@yourdomain.com>
WAITLIST_FROM_EMAIL=

# Optional: port for the waitlist API (default 8787). Must match vite proxy target.
# WAITLIST_SERVER_PORT=8787

# Optional: browser origin when the SPA is hosted on a different domain than the API (e.g. https://payvol.com).
# CORS_ORIGIN=http://localhost:5173

# Optional: full URL of the API when the built SPA is not served with a same-origin /api proxy.
# Example: https://your-api.railway.app — omit trailing slash.
# VITE_API_URL=

# Firebase
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-key.json
